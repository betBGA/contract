# Private key of the deployer wallet (without 0x prefix is fine too)
DEPLOYER_PRIVATE_KEY=

# RPC endpoints (optional — defaults are provided in hardhat.config.ts)
AMOY_RPC_URL=https://polygon-amoy.drpc.org
POLYGON_RPC_URL=https://polygon.drpc.org

# USDT token contract address for the target network
USDT_ADDRESS=

# Oracle wallet addresses (4 unique addresses)
ORACLE_1=
ORACLE_2=
ORACLE_3=
ORACLE_4=

# Deployed contract address (needed for halt/resume scripts)
BGAMBLE_ADDRESS=

# Polygonscan API key (for contract verification — get one at https://polygonscan.com/apis)
POLYGONSCAN_API_KEY=

