# Copy this file to create your environment files:
#   cp .env.example .env.testnet   — for Amoy testnet
#   cp .env.example .env.mainnet   — for Polygon mainnet
# Then fill in the values for each network.

# Private key of the deployer wallet (without 0x prefix is fine too)
DEPLOYER_PRIVATE_KEY=

# RPC endpoint (optional — defaults are provided in hardhat.config.ts)
# Use AMOY_RPC_URL in .env.testnet and POLYGON_RPC_URL in .env.mainnet
AMOY_RPC_URL=https://polygon-amoy.drpc.org
POLYGON_RPC_URL=https://polygon.drpc.org

# USDT token contract address for the target network
USDT_ADDRESS=

# Oracle wallet addresses (4 unique addresses)
ORACLE_1=
ORACLE_2=
ORACLE_3=
ORACLE_4=

# Deployed contract address (needed for halt/resume scripts)
BGAMBLE_ADDRESS=

# Polygonscan API key (for contract verification — get one at https://polygonscan.com/apis)
POLYGONSCAN_API_KEY=

