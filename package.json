{
  "name": "bgamble",
  "version": "1.0.0",
  "type": "module",
  "description": "BGAmble.sol — smart contract for betting on the outcome of online boardgames at Board Game Arena.",
  "scripts": {
    "build": "hardhat build",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network amoy",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network polygon",
    "halt:testnet": "ACCEPTING=false hardhat run scripts/setAcceptingNewBets.js --network amoy",
    "halt:mainnet": "ACCEPTING=false hardhat run scripts/setAcceptingNewBets.js --network polygon",
    "resume:testnet": "ACCEPTING=true hardhat run scripts/setAcceptingNewBets.js --network amoy",
    "resume:mainnet": "ACCEPTING=true hardhat run scripts/setAcceptingNewBets.js --network polygon"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.3",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.11",
    "@nomicfoundation/hardhat-verify": "^3.0.12",
    "@types/node": "^22.8.5",
    "chai": "^5.1.2",
    "ethers": "^6.14.0",
    "hardhat": "^3.1.12",
    "typescript": "~5.8.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.3.1"
  },
  "overrides": {
    "undici": "^6.24.0"
  }
}
